from kernel.action_registry import ActionRegistry
from tools.tool_registry import ToolRegistry
from services.service_registry import ServiceRegistry

class Dispatcher:

    def __init__(self):

        self.actions = ActionRegistry()
        self.tools = ToolRegistry()
        self.services = ServiceRegistry()

    def dispatch(self, task):

        print()
        print(f"[Dispatcher] Action: {task.action}")

        route = self.actions.get(task.action)

        if route:

            tool_name, method_name = route

            tool = self.tools.get(tool_name)

            method = getattr(tool, method_name)

            if task.action == "remember":

                result = method(task.data[0], task.data[1])

            else:

                result = method(task.data)

            print(result)

            return result

        if task.action in ["chat", "generate_code"]:

            llm = self.services.get("llm")

            result = llm.ask(task.data, task.model)

            print()
            print("AMALGAM:\n")
            print(result)

            return result

        print("Unknown action.")

        return None
