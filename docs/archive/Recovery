class IntentAnalyzer:

    def analyze(self, text: str):

        text = text.lower()

        if any(word in text for word in [
            "python", "code", "java", "c++", "bug",
            "debug", "program", "algorithm"
        ]):
            return "coding"

        if any(word in text for word in [
