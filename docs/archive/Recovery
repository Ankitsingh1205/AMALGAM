                self.logger.error(message, tool=tool_name)
                return message

            method = getattr(tool, method_name, None)

            if method is None:
                message = f"Dispatcher Error: missing method '{method_name}' on tool '{tool_name}'."
                self.logger.error(message, tool=tool_name, method=method_name)
                return message

