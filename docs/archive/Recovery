def search_symbols(self, query, symbols):
    query = query.lower()

    results = [
        symbol
        for symbol in symbols
        if query in symbol["name"].lower()
        or query in symbol["qualified_name"].lower()
    ]

    # Prefer classes, then functions, then modules
    priority = {
        "class": 0,
        "function": 1,
        "module": 2,
